package es.um.atica.umufly.parking.domain.model;

import java.sql.Timestamp;
import java.util.UUID;

import es.um.atica.umufly.vuelos.domain.model.DocumentoIdentidad;

// Agregado raíz
public class ReservaParking {

	private UUID id;
	private DocumentoIdentidad identificadorTitular;
	private TipoReserva tipoReserva;
	private PeriodoEstacionamiento periodo;
	private Importe importe;
	private Timestamp fechaReserva;
	private EstadoReserva estadoReserva;

	public ReservaParking( UUID id, DocumentoIdentidad identificadorTitular, TipoReserva tipoReserva, PeriodoEstacionamiento periodo, Importe importe, Timestamp fechaReserva, EstadoReserva estadoReserva ) {
		this.id = id;
		this.identificadorTitular = identificadorTitular;
		this.tipoReserva = tipoReserva;
		this.periodo = periodo;
		this.importe = importe;
		this.fechaReserva = fechaReserva;
		this.estadoReserva = estadoReserva;
	}
	
	 public static ReservaParking crear(DocumentoIdentidad identificadorPasajero,
             TipoReserva tipo,
             Periodo periodo,
             Importe importeBase,
             boolean tieneReservaVuelo,
             boolean vueloRealizado) {

return new ReservaParking(
UUID.randomUUID(),
identificadorPasajero,
tipo,
periodo,
importeBase,
tieneReservaVuelo,
vueloRealizado
);
}

private Importe aplicarDescuentoSiCorresponde(Importe importeBase) {
if (tieneReservaVuelo && !vueloRealizado) {
return importeBase.aplicarDescuento(new BigDecimal("0.75"));
}
return importeBase;
}

public void cancelar() {
if (estado == EstadoReserva.CANCELADA) {
throw new IllegalStateException("La reserva ya está cancelada");
}

if (LocalDateTime.now().isAfter(periodoEstacionamiento.getInicio())) {
throw new IllegalStateException("No se puede cancelar después del inicio del periodo");
}

this.estado = EstadoReserva.CANCELADA;
}

public boolean estaActiva() {
return this.estado == EstadoReserva.ACTIVA;
}

	public UUID getId() {
		return id;
	}

	public void setId( UUID id ) {
		this.id = id;
	}

	public DocumentoIdentidad getIdentificadorTitular() {
		return identificadorTitular;
	}

	public void setIdentificadorTitular( DocumentoIdentidad identificadorTitular ) {
		this.identificadorTitular = identificadorTitular;
	}

	public TipoReserva getTipoReserva() {
		return tipoReserva;
	}

	public void setTipoReserva( TipoReserva tipoReserva ) {
		this.tipoReserva = tipoReserva;
	}

	public PeriodoEstacionamiento getPeriodo() {
		return periodo;
	}

	public void setPeriodo( PeriodoEstacionamiento periodo ) {
		this.periodo = periodo;
	}

	public Importe getImporte() {
		return importe;
	}

	public void setImporte( Importe importe ) {
		this.importe = importe;
	}

	public Timestamp getFechaReserva() {
		return fechaReserva;
	}

	public void setFechaReserva( Timestamp fechaReserva ) {
		this.fechaReserva = fechaReserva;
	}

	public EstadoReserva getEstadoReserva() {
		return estadoReserva;
	}

	public void setEstadoReserva( EstadoReserva estadoReserva ) {
		this.estadoReserva = estadoReserva;
	}

}
