package es.um.atica.umufly.parking.domain.model;

import java.math.BigDecimal;
import java.math.RoundingMode;
import java.util.Objects;

public class Importe {

	private final BigDecimal valor;

	public Importe( BigDecimal valor ) {
		if ( valor.compareTo( BigDecimal.ZERO ) < 0 ) {
			throw new IllegalArgumentException( "El importe no puede ser negativo" );
		}
		this.valor = valor;
	}

	public Importe aplicarDescuento( BigDecimal porcentaje ) {
		BigDecimal descuento = valor.multiply( porcentaje );
		BigDecimal nuevoValor = valor.subtract( descuento );
		return new Importe( nuevoValor.setScale( 2, RoundingMode.HALF_UP ) );
	}

	public BigDecimal getValor() {
		return valor;
	}
}
