package es.um.atica.umufly.vuelos.application.usecase.cancelarreservas;

import java.util.UUID;

import es.um.atica.fundewebjs.umubus.domain.cqrs.SyncCommand;
import es.um.atica.umufly.vuelos.application.usecase.crearreservas.CreaReservasCommand;
import es.um.atica.umufly.vuelos.domain.model.ClaseAsientoReserva;
import es.um.atica.umufly.vuelos.domain.model.DocumentoIdentidad;
import es.um.atica.umufly.vuelos.domain.model.Pasajero;

public class CancelarReservasCommand extends SyncCommand<Void> {
	

	private DocumentoIdentidad documentoIdentidadTitular;
	private UUID idVuelo;


	public CreaReservasCommand( DocumentoIdentidad documentoIdentidadTitular, UUID idVuelo ) {
		this.documentoIdentidadTitular = documentoIdentidadTitular;
		this.idVuelo = idVuelo;
	}

	public static CreaReservasCommand of( DocumentoIdentidad documentoIdentidadTitular, UUID idVuelo ) {

		return new CreaReservasCommand( documentoIdentidadTitular, idVuelo );
	}

	public DocumentoIdentidad getDocumentoIdentidadTitular() {
		return documentoIdentidadTitular;
	}

	public UUID getIdVuelo() {
		return idVuelo;
	}

}
